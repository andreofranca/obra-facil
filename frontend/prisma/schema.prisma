generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  phone        String?
  password     String
  role         UserRole
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cliente      Cliente?
  profissional Profissional?

  @@map("users")
}

model Cliente {
  id           String             @id @default(uuid())
  userId       String             @unique
  user         User               @relation(fields: [userId], references: [id])
  solicitacoes SolicitarServico[]

  @@map("clients")
}

model Profissional {
  id          String      @id @default(uuid())
  userId      String      @unique
  descricao   String?
  experiencia Int?
  ativo       Boolean     @default(true)
  user        User        @relation(fields: [userId], references: [id])
  avaliacoes  Avaliacao[]
  servicos    Servico[]

  @@map("professionals")
}

model CategoriaServico {
  id       String    @id @default(uuid())
  nome     String    @unique
  servicos Servico[]

  @@map("service_categories")
}

model Servico {
  id             String           @id @default(uuid())
  titulo         String
  descricao      String?
  categoriaId    String
  profissionalId String
  categoria      CategoriaServico @relation(fields: [categoriaId], references: [id])
  profissional   Profissional     @relation(fields: [profissionalId], references: [id])

  @@map("services")
}

model SolicitarServico {
  id        String                @id @default(uuid())
  titulo    String
  descricao String
  status    SolicitacaoStatus     @default(ABERTA)
  clienteId String
  createdAt DateTime              @default(now())
  updatedAt DateTime
  mensagens MensagemSolicitacao[]
  cliente   Cliente               @relation(fields: [clienteId], references: [id])

  @@map("service_requests")
}

model MensagemSolicitacao {
  id            String           @id @default(uuid())
  solicitacaoId String
  mensagem      String
  createdAt     DateTime         @default(now())
  solicitacao   SolicitarServico @relation(fields: [solicitacaoId], references: [id])

  @@map("service_request_messages")
}

model Avaliacao {
  id             String       @id @default(uuid())
  nota           Int
  comentario     String?
  profissionalId String
  createdAt      DateTime     @default(now())
  profissional   Profissional @relation(fields: [profissionalId], references: [id])

  @@map("ratings")
}

enum UserRole {
  CLIENT
  PROFESSIONAL
  ADMIN
}

enum SolicitacaoStatus {
  ABERTA
  EM_ANALISE
  ACEITA
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}
